      "fix_code": "Restructure mobile navigation with clearer hierarchy and better CTAs:\n\n```tsx\nconst items = [\n  { icon: Home, label: \"Главная\", href: \"/\" },\n  { icon: UtensilsCrossed, label: \"Меню\", href: \"/menu\" },\n  { icon: Calculator, label: \"Калькулятор\", href: \"/menu#calculator\" },\n  { icon: Image, label: \"Галерея\", href: \"/gallery\" },\n  { icon: Phone, label: \"Контакты\", href: \"/contact\" },\n];\n\n// Replace WhatsApp button with dynamic cart button\nconst getWhatsAppUrl = () => {\n  let text = \"Здравствуйте! Хочу узнать о кейтеринге.\";\n  try {\n    const stored = localStorage.getItem(\"nilov-cart\");\n    if (stored) {\n      const parsed = JSON.parse(stored);\n      if (Array.isArray(parsed) && parsed.length > 0) {\n        let total = 0;\n        let menuText = \"Здравствуйте! Хочу заказать кейтеринг. Моё меню:\\n\\n\";\n        parsed.forEach(([, { item, quantity }]) => {\n          const sum = item.price * quantity;\n          total += sum;\n          menuText += `• ${item.name} x${quantity} — ${sum.toLocaleString(\"ru-RU\")} ₽\\n`;\n        });\n        menuText += `\\nИтого: ${total.toLocaleString(\"ru-RU\")} ₽`;\n        text = menuText;\n      }\n    }\n  } catch {}\n  return `https://wa.me/74959213456?text=${encodeURIComponent(text)}`;\n};\n\n// Update mobile nav to show cart count\nconst CartButton = () => {\n  const [count, setCount] = useState(0);\n  \n  useEffect(() => {\n    const updateCount = () => {\n      try {\n        const stored = localStorage.getItem(\"nilov-cart\");\n        if (stored) {\n          const parsed = JSON.parse(stored);\n          const total = Array.from(parsed.values()).reduce((acc, { quantity }) => acc + quantity, 0);\n          setCount(total);\n        }\n      } catch {}\n    };\n    \n    updateCount();\n    window.addEventListener(\"storage\", updateCount);\n    return () => window.removeEventListener(\"storage\", updateCount);\n  }, []);\n  \n  return (\n    <Link href=\"/menu\" className=\"relative flex flex-col items-center gap-0.5 py-1 px-2 rounded-lg transition-colors min-w-0\">\n      <UtensilsCrossed className={cn(\n        \"w-5 h-5 shrink-0 transition-colors\",\n        pathname === \"/menu\" ? \"text-accent\" : \"text-muted-foreground\"\n      )} />\n      <span\n        className={cn(\n          \"text-[10px] leading-tight truncate transition-colors\",\n          pathname === \"/menu\" ? \"text-accent font-medium\" : \"text-muted-foreground\"\n        )}\n      >\n        Меню\n      </span>\n      {count > 0 && (\n        <motion.span \n          initial={{ scale: 0 }}\n          animate={{ scale: 1 }}\n          className=\"absolute -top-1 -right-1 w-5 h-5 bg-accent text-white text-xs rounded-full flex items-center justify-center\"\n        >\n          {count > 99 ? \"99+\" : count}\n        </motion.span>\n      )}\n    </Link>\n  );\n};\n```"
