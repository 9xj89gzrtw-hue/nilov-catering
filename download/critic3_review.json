      "fix_code": "Improve API routes with proper error handling and structured responses:\n\n```tsx\n// Enhanced contact API route\nexport async function POST(request: NextRequest) {\n  try {\n    const body = await request.json();\n    const result = contactSchema.safeParse(body);\n    \n    if (!result.success) {\n      return NextResponse.json(\n        { \n          success: false, \n          errors: result.error.flatten().fieldErrors,\n          message: \"Пожалуйста, исправьте ошибки в форме\"\n        }, \n        { status: 400 }\n      );\n    }\n    \n    // Here you would typically save to database and send email\n    console.log(\"Contact form:\", result.data);\n    \n    // Simulate processing delay\n    await new Promise(resolve => setTimeout(resolve, 1000));\n    \n    return NextResponse.json({ \n      success: true,\n      message: \"Сообщение успешно отправлено. Мы свяжемся с вами в ближайшее время.\"\n    });\n  } catch (error) {\n    console.error(\"Contact form error:\", error);\n    return NextResponse.json(\n      { \n        success: false, \n        message: \"Произошла ошибка при отправке. Пожалуйста, попробуйте ещё раз.\"\n      }, \n      { status: 500 }\n    );\n  }\n}\n\n// Enhanced quote API route\nexport async function POST(request: NextRequest) {\n  try {\n    const body = await request.json();\n    \n    // Validate required fields\n    const requiredFields = [\n      'eventType', 'date', 'time', 'guestCount', \n      'serviceFormat', 'packageId', 'name', 'phone', 'email'\n    ];\n    \n    const missingFields = requiredFields.filter(field => !body[field]);\n    if (missingFields.length > 0) {\n      return NextResponse.json(\n        { \n          success: false, \n          message: `Пожалуйста, заполните все обязательные поля: ${missingFields.join(', ')}`\n        }, \n        { status: 400 }\n      );\n    }\n    \n    // Here you would save to database and send notification\n    console.log(\"Quote request received:\", body);\n    \n    // Simulate processing\n    await new Promise(resolve => setTimeout(resolve, 1500));\n    \n    return NextResponse.json({ \n      success: true,\n      message: \"Заявка успешно отправлена! Менеджер свяжется с вами в течение 2 часов для уточнения деталей.\",\n      quoteId: `Q${Date.now()}`\n    });\n  } catch (error) {\n    console.error(\"Quote request error:\", error);\n    return NextResponse.json(\n      { \n        success: false, \n        message: \"Ошибка при обработке заявки. Пожалуйста, попробуйте ещё раз или позвоните нам напрямую.\"\n      }, \n      { status: 500 }\n    );\n  }\n}\n```"
